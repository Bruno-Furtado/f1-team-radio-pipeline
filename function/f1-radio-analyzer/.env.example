# Override only if you need to. Defaults are sensible for the demo.
# PROJECT_ID is derived from gcloud at deploy time.

GEMINI_MODEL=gemini-2.5-flash
GEMINI_LOCATION=us-central1
FALLBACK_MODEL=gemini-3.1-pro-preview
FALLBACK_LOCATION=global
FILE_LIMIT=200
CONCURRENCY_LIMIT=10
PRIMARY_RPM=150
FALLBACK_RPM=30
MAX_RETRIES_429=3
